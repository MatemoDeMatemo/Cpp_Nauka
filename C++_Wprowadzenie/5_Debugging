// Debuggowanie przyklady
#include <iostream>


// Ta funkcja przyda sie dopiero na etapie nr 3]
int silnia(int x)
{   
    int wynik = 1;

    for(int s = 1; s < x +1; s++){ 
        wynik = wynik * s;
        }

    return wynik;

}


// By rozpoczac debuggowanie wcisnij F5
int main()
{          
    // 1] Wstawianie prostych breakpoint'sow (BP)
    // By postawic BP zaznacz na lewej strone edyora czerwona kropke. Program przy debugowaniu zatrzyma sie na tej linii kodu. 
    // BP bedzie pokazywac stan przed wykonaniem danej linii. 
    std::cout << "hello1" << std::endl;

    int a = 2;
    int b = 3; 

    std::cout << "hello2" << std::endl;

    std::cout << a << std::endl;
    
    a = a + 2;
    std::cout << a << std::endl;
    a = a + b;

    // 2] Petla for
    // By sprawdzic dzialanie petli zaznaczamy BP na linii z "for" a nastepnie wciskamy F10. Pozwala nam to iterowac linia po linii
    // Mozliwe jest stawianie BP z warunkiem - w ustawieniach BP
    int suma = 0;
    for (int i = 0; i < 3; i++) {
        suma = a + i;
        std::cout << suma << std::endl;
    }


    // 3] Funkcja
    // By "zajrzec" do wnetrza dzialania funkji zadeklarowanej wczesniej musimy wcisnac F11. 
    int silnia_wynik = silnia(5);
    std::cout << "Wynik silni to: " << silnia_wynik << std::endl;


    return 0;
}
